<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="DiscUtils.Fat" Version="0.16.13" />
    <PackageReference Include="SharpCompress" Version="0.49.1" />
  </ItemGroup>

  <ItemGroup>
    <None Update="boot/**/*" CopyToOutputDirectory="PreserveNewest" />
    <None Update="ventoy/**/*" CopyToOutputDirectory="PreserveNewest" />
    <None Update="tool/**/*" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
